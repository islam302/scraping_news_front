{
  "routes": [
    {
      "src": "/auth-api/(.*)",
      "dest": "https://una-ai-tools-apis.una-oic.org/auth-api/$1"
    },
    {
      "src": "/scraping-api/(.*)",
      "dest": "/api/scraping-proxy"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
